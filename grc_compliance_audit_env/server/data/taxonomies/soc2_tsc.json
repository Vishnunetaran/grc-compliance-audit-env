          "category": "Control Environment",
          "keywords": ["integrity", "ethical values", "code of conduct", "ethics"]
        },
        {
          "id": "CC1.2",
          "name": "COSO Principle 2: Board exercises oversight responsibility",
          "category": "Control Environment",
          "keywords": ["board oversight", "governance", "board of directors"]
        },
        {
          "id": "CC1.3",
          "name": "COSO Principle 3: Establishes structure, authority, and responsibility",
          "category": "Control Environment",
          "keywords": ["organizational structure", "authority", "responsibility", "reporting lines"]
        },
        {
          "id": "CC1.4",
          "name": "COSO Principle 4: Demonstrates commitment to competence",
          "category": "Control Environment",
          "keywords": ["competence", "training", "skills", "awareness", "security training"]
        },
        {
          "id": "CC1.5",
          "name": "COSO Principle 5: Enforces accountability",
          "category": "Control Environment",
          "keywords": ["accountability", "performance", "responsibility"]
        },
        {
          "id": "CC2.1",
          "name": "COSO Principle 13: Obtains or generates relevant, quality information",
          "category": "Communication and Information",
          "keywords": ["information quality", "relevant information", "data quality"]
        },
        {
          "id": "CC2.2",
          "name": "COSO Principle 14: Internally communicates information",
          "category": "Communication and Information",
          "keywords": ["internal communication", "security communication", "policies communication"]
        },
        {
          "id": "CC2.3",
          "name": "COSO Principle 15: Externally communicates information",
          "category": "Communication and Information",
          "keywords": ["external communication", "external reporting", "stakeholder communication"]
        },
        {
          "id": "CC3.1",
          "name": "COSO Principle 6: Specifies suitable objectives",
          "category": "Risk Assessment",
          "keywords": ["risk objectives", "security objectives"]
